# 服务器配置
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# 客户端 URL（CORS）
CLIENT_URL=http://localhost:5173

# 数据库
DATABASE_URL=postgresql://postgres:password@localhost:5432/albion_lands?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 游戏配置
GAME_SERVER_NAME=Albion Lands
MAX_PLAYERS_PER_ZONE=100
TICK_RATE=30
