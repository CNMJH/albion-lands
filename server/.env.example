# 服务器配置
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
LOG_LEVEL=info

# 客户端 URL（CORS）
CLIENT_URL=http://localhost:3001

# 数据库（SQLite）
DATABASE_URL=file:./dev.db

# JWT
JWT_SECRET=hululands-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 游戏配置
GAME_SERVER_NAME=呼噜大陆 (Hulu Lands)
MAX_PLAYERS_PER_ZONE=50
TICK_RATE=30
