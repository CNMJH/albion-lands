generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  character Character?
}

model Character {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  name            String
  level           Int             @default(1)
  exp             Int             @default(0)
  silver          Int             @default(0)
  gold            Int             @default(0)
  zoneId          String          @default("zone_1")
  x               Float           @default(0)
  y               Float           @default(0)
  respawnMapId    String?         // 绑定的复活点地图
  respawnX        Float?          // 复活点 X 坐标
  respawnY        Float?          // 复活点 Y 坐标
  equipment       String? // JSON string: {"MainHand": "uuid", "OffHand": "uuid", ...}
  stats           String? // JSON string: {"attack": 100, "defense": 50, "hp": 500, ...}
  isOnline        Boolean         @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  inventory       InventoryItem[]
  partyMembers    PartyMember[]
  chatMessages    ChatMessage[]
  friendsSent     Friend[]        @relation("CharacterFriendsSent")
  friendsReceived Friend[]        @relation("CharacterFriendsReceived")
  questProgress   QuestProgress[]
  achievementProgress AchievementProgress[]
  characterSkills CharacterSkill[]
  deathRecords    DeathRecord[]   // 死亡记录
  pvpStats        PVPStats?       // PVP 统计
  kills           PlayerKill[]    @relation("KillerKills")
  deaths          PlayerKill[]    @relation("VictimKills")
  marketOrders    MarketOrder[]
  soldItems       TransactionHistory[] @relation("SellerTransactions")
  boughtItems     TransactionHistory[] @relation("BuyerTransactions")
}

model Item {
  id             String          @id @default(uuid())
  name           String
  type           String // Weapon, Armor, Material, Tool, Consumable...
  rarity         String // Common, Uncommon, Rare, Legendary
  stats          String? // JSON string: {"attack": 50, "defense": 0, "hp": 0}
  slot           String? // MainHand, OffHand, Armor, Legs, Boots, Accessory
  equipmentType  String? // Weapon, Armor, Accessory, Tool
  icon           String?
  description    String?
  minLevel       Int             @default(1)
  stackSize      Int             @default(99)
  basePrice      Int             @default(0)
  tier           String          @default("T1") // T1, T2, T3, T4, T5
  quality        String          @default("Common") // Common, Uncommon, Legendary
  specialEffect  String? // 特殊效果描述
  createdAt      DateTime        @default(now())
  inventoryItems InventoryItem[]
  marketOrders   MarketOrder[]
  droppedItems   DroppedItem[]   // 掉落物品
  tradeItems     TradeItem[]
}

model InventoryItem {
  id          String    @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  quantity    Int       @default(1)
  isEquipped  Boolean   @default(false)
  durability  Int       @default(100) // 耐久度 (0-100)
  createdAt   DateTime  @default(now())
}

model MarketOrder {
  id        String   @id @default(uuid())
  sellerId  String
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  quantity  Int
  unitPrice Int
  type      String   @default("SELL") // SELL, BUY
  status    String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, EXPIRED
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  seller    Character @relation(fields: [sellerId], references: [id])
  
  @@index([sellerId])
  @@index([itemId])
  @@index([status])
  @@index([type])
}

model Zone {
  id          String   @id @default(uuid())
  name        String
  safetyLevel Int      @default(10)
  minLevel    Int      @default(1)
  maxLevel    Int      @default(10)
  pvpEnabled  Boolean  @default(false)
  portals     String? // JSON string
  createdAt   DateTime @default(now())
}

// 死亡记录
model DeathRecord {
  id          String   @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  killerId    String?  // 击杀者 (PVP 时)
  mapId       String   // 死亡地图
  safetyLevel Int      // 安全等级
  droppedItems String  // JSON string: [{itemId, itemName, slot}]
  createdAt   DateTime @default(now())
}

// 掉落物品
model DroppedItem {
  id          String   @id @default(uuid())
  mapId       String   // 掉落地图
  x           Int      // X 坐标
  y           Int      // Y 坐标
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id])
  ownerId     String?  // 原主人 (可拾取保护)
  quantity    Int      @default(1)
  expireAt    DateTime // 过期时间 (30 分钟)
  createdAt   DateTime @default(now())
}

model Friend {
  id          String   @id @default(uuid())
  characterId String
  friendId    String
  status      String   @default("pending") // pending, accepted, blocked
  createdAt   DateTime @default(now())

  character Character @relation("CharacterFriendsSent", fields: [characterId], references: [id], onDelete: Cascade)
  friend    Character @relation("CharacterFriendsReceived", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([characterId, friendId])
}

model Party {
  id         String        @id @default(uuid())
  leaderId   String
  name       String?
  maxMembers Int           @default(3)
  isPublic   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  members    PartyMember[]
}

model PartyMember {
  id          String    @id @default(uuid())
  partyId     String
  party       Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  role        String    @default("Member") // Leader, Member
  joinedAt    DateTime  @default(now())

  @@unique([partyId, characterId])
}

model ChatMessage {
  id         String    @id @default(uuid())
  type       String // whisper, party, zone, global
  senderId   String
  sender     Character @relation(fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String? // whisper 目标
  partyId    String? // 队伍 ID
  zoneId     String? // 区域 ID
  content    String
  createdAt  DateTime  @default(now())
}

model GameLog {
  id          String   @id @default(uuid())
  type        String
  message     String
  data        String? // JSON string
  characterId String?
  createdAt   DateTime @default(now())
}

// ============================================
// 任务系统 - 阶段 6
// ============================================

// NPC 模型 - 任务发布者
model NPC {
  id          String   @id @default(uuid())
  name        String   // NPC 名称
  type        String   @default("quest") // quest, merchant, service
  zoneId      String   // 所在区域
  x           Float    // X 坐标
  y           Float    // Y 坐标
  dialogue    String?  // JSON 字符串，对话内容
  givenQuests     Quest[]    @relation("NPCGiver")
  receivedQuests  Quest[]    @relation("NPCReceiver")
  quests      NPCQuest[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 任务模板 - 任务定义
model Quest {
  id            String   @id @default(uuid())
  name          String   // 任务名称
  description   String   // 任务描述
  type          String   @default("main") // main, side, daily, weekly
  level         Int      @default(1) // 推荐等级
  difficulty    String   @default("normal") // easy, normal, hard
  category      String?  // main_story, side, gathering, combat, delivery
  
  // 任务目标（JSON 格式）
  objectives    String?
  
  // 前置任务
  prerequisites String?  // JSON 数组，前置任务 ID 列表
  
  // 奖励
  expReward     Int      @default(0)
  silverReward  Int      @default(0)
  goldReward    Int      @default(0)
  itemRewards   String?  // JSON 数组，奖励物品 [{itemId, quantity}]
  
  // 重复性
  isRepeatable  Boolean  @default(false)
  repeatCooldown Int     @default(0) // 冷却时间（秒）
  
  // 时间限制
  timeLimit     Int?     // 时间限制（秒）
  
  // 关联 NPC
  giverId       String?  // 发布任务的 NPC
  receiverId    String?  // 提交任务的 NPC
  
  giver         NPC?     @relation("NPCGiver", fields: [giverId], references: [id])
  receiver      NPC?     @relation("NPCReceiver", fields: [receiverId], references: [id])
  
  quests        NPCQuest[]
  progress      QuestProgress[]
  dailyQuests   DailyQuest[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// NPC-任务关联
model NPCQuest {
  id        String   @id @default(uuid())
  npcId     String
  questId   String
  type      String   @default("give") // give, receive, both
  
  npc       NPC      @relation(fields: [npcId], references: [id], onDelete: Cascade)
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  
  @@unique([npcId, questId])
  @@index([npcId])
  @@index([questId])
}

// 任务进度 - 玩家任务状态
model QuestProgress {
  id          String   @id @default(uuid())
  characterId String
  questId     String
  status      String   @default("in_progress") // in_progress, completed, failed, abandoned
  
  // 目标进度（JSON 格式）
  progress    String?
  
  // 时间追踪
  startedAt   DateTime @default(now())
  completedAt DateTime?
  failedAt    DateTime?
  abandonedAt DateTime?
  
  // 重复追踪
  completedCount Int   @default(0)
  lastCompletedAt DateTime?
  
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  
  @@unique([characterId, questId])
  @@index([characterId])
  @@index([questId])
  @@index([status])
}

// 每日任务
model DailyQuest {
  id          String   @id @default(uuid())
  questId     String
  name        String
  description String
  type        String   @default("daily") // daily, weekly
  
  pool        String?  // 任务池名称
  refreshTime String   @default("00:00")
  
  expReward   Int      @default(0)
  silverReward Int     @default(0)
  goldReward  Int      @default(0)
  itemRewards String?
  
  maxPerDay   Int      @default(1)
  
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type])
  @@index([pool])
}

// 成就系统
model Achievement {
  id          String   @id @default(uuid())
  name        String
  description String
  category    String   // combat, gathering, crafting, social, exploration
  type        String   // kill, collect, craft, reach_level, explore...
  
  targetType  String?
  targetId    String?
  targetCount Int      @default(1)
  
  expReward   Int      @default(0)
  silverReward Int     @default(0)
  goldReward  Int      @default(0)
  title       String?
  badge       String?
  
  prerequisites String?
  isHidden    Boolean  @default(false)
  isRepeatable Boolean @default(false)
  
  progress    AchievementProgress[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([type])
}

// 成就进度
model AchievementProgress {
  id            String   @id @default(uuid())
  characterId   String
  achievementId String
  current       Int      @default(0)
  completed     Boolean  @default(false)
  completedAt   DateTime?
  completedCount Int     @default(0)
  
  character     Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  @@unique([characterId, achievementId])
  @@index([characterId])
  @@index([achievementId])
  @@index([completed])
}

// ============================================
// 技能系统
// ============================================

// 技能模板
model Skill {
  id              String   @id @default(uuid())
  name            String   // 技能名称
  description     String   // 技能描述
  type            String   // Damage, Heal, Buff, Debuff, Dash, Shield
  weaponType      String   // 关联武器类型
  damageMultiplier Float?  // 伤害倍率
  healAmount      Int?     // 治疗量
  cooldown        Int      // 冷却时间（秒）
  energyCost      Int      // 能量消耗
  range           Int      // 施法距离
  duration        Int?     // 持续时间（秒）
  radius          Int?     // 作用半径
  icon            String?  // 技能图标
  
  characterSkills CharacterSkill[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([weaponType])
  @@index([type])
}

// 角色技能
model CharacterSkill {
  id          String   @id @default(uuid())
  characterId String
  skillId     String
  level       Int      @default(1) // 技能等级
  slot        Int      @default(-1) // 快捷栏位 (0-7, -1 未装备)
  cooldownUntil DateTime? // 冷却结束时间
  
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  @@unique([characterId, skillId])
  @@index([characterId])
}

// PVP 统计
model PVPStats {
  id          String   @id @default(uuid())
  characterId String   @unique
  kills       Int      @default(0)
  deaths      Int      @default(0)
  assists     Int      @default(0)
  honorPoints Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

// 玩家击杀记录
model PlayerKill {
  id        String   @id @default(uuid())
  killerId  String
  victimId  String
  mapId     String
  timestamp DateTime @default(now())
  
  killer    Character @relation("KillerKills", fields: [killerId], references: [id], onDelete: Cascade)
  victim    Character @relation("VictimKills", fields: [victimId], references: [id], onDelete: Cascade)
  
  @@index([killerId])
  @@index([victimId])
  @@index([timestamp])
}

// 交易记录
model Trade {
  id            String    @id @default(uuid())
  initiatorId   String
  recipientId   String
  status        String    @default("PENDING") // PENDING, ACCEPTED, COMPLETED, CANCELLED
  initiatorSilver Int     @default(0)
  recipientSilver Int     @default(0)
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  
  items         TradeItem[]
  
  @@index([initiatorId])
  @@index([recipientId])
  @@index([status])
}

// 交易物品
model TradeItem {
  id          String   @id @default(uuid())
  tradeId     String
  ownerId     String   // 原所有者 ID
  itemId      String
  quantity    Int      @default(1)
  slot        String   // INITIATOR, RECIPIENT
  
  trade       Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  item        Item     @relation(fields: [itemId], references: [id])
  
  @@index([tradeId])
  @@index([slot])
}

// 交易历史
model TransactionHistory {
  id        String   @id @default(uuid())
  orderId   String
  buyerId   String
  sellerId  String
  itemId    String
  quantity  Int
  price     Int      // 成交价
  tax       Int      @default(0) // 税费
  createdAt DateTime @default(now())
  
  seller    Character @relation("SellerTransactions", fields: [sellerId], references: [id])
  buyer     Character @relation("BuyerTransactions", fields: [buyerId], references: [id])
  
  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([createdAt])
}
