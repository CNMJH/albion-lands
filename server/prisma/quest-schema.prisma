// 任务系统 Prisma Schema
// 添加到现有 schema.prisma

// ============================================
// NPC 模型 - 任务发布者
// ============================================
model NPC {
  id          String   @id @default(uuid())
  name        String   // NPC 名称
  type        String   @default("quest") // quest, merchant, service
  zoneId      String   // 所在区域
  x           Float    // X 坐标
  y           Float    // Y 坐标
  dialogue    String?  // JSON 字符串，对话内容
  quests      NPCQuest[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// 任务模板 - 任务定义
// ============================================
model Quest {
  id            String   @id @default(uuid())
  name          String   // 任务名称
  description   String   // 任务描述
  type          String   @default("main") // main, side, daily, weekly
  level         Int      @default(1) // 推荐等级
  difficulty    String   @default("normal") // easy, normal, hard
  category      String?  // 任务分类：main_story, side, gathering, combat, delivery
  
  // 任务目标（JSON 格式）
  // 示例：[{"type": "kill", "targetId": "monster_1", "count": 10}, {"type": "collect", "targetId": "item_1", "count": 5}]
  objectives    String?
  
  // 前置任务
  prerequisites String?  // JSON 数组，前置任务 ID 列表
  
  // 奖励
  expReward     Int      @default(0)
  silverReward  Int      @default(0)
  goldReward    Int      @default(0)
  itemRewards   String?  // JSON 数组，奖励物品 [{itemId, quantity}]
  
  // 重复性
  isRepeatable  Boolean  @default(false)
  repeatCooldown Int     @default(0) // 冷却时间（秒）
  
  // 时间限制
  timeLimit     Int?     // 时间限制（秒），null 表示无限制
  
  // 关联 NPC
  giverId       String?  // 发布任务的 NPC
  receiverId    String?  // 提交任务的 NPC（可与 giver 相同）
  
  quests        NPCQuest[]
  progress      QuestProgress[]
  dailyQuests   DailyQuest[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================
// NPC-任务关联 - 多对多关系
// ============================================
model NPCQuest {
  id        String   @id @default(uuid())
  npcId     String
  questId   String
  type      String   @default("give") // give, receive, both
  
  npc       NPC      @relation(fields: [npcId], references: [id], onDelete: Cascade)
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  
  @@unique([npcId, questId])
  @@index([npcId])
  @@index([questId])
}

// ============================================
// 任务进度 - 玩家任务状态
// ============================================
model QuestProgress {
  id          String   @id @default(uuid())
  characterId String
  questId     String
  status      String   @default("in_progress") // in_progress, completed, failed, abandoned
  
  // 目标进度（JSON 格式）
  // 示例：[{"objectiveIndex": 0, "current": 5, "required": 10, "completed": false}]
  progress    String?
  
  // 时间追踪
  startedAt   DateTime @default(now())
  completedAt DateTime?
  failedAt    DateTime?
  abandonedAt DateTime?
  
  // 重复追踪
  completedCount Int   @default(0) // 已完成次数（可重复任务）
  lastCompletedAt DateTime? // 上次完成时间
  
  character   Quest    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  
  @@unique([characterId, questId])
  @@index([characterId])
  @@index([questId])
  @@index([status])
}

// ============================================
// 每日任务 - 特殊任务类型
// ============================================
model DailyQuest {
  id          String   @id @default(uuid())
  questId     String
  name        String   // 任务名称（冗余，方便查询）
  description String   // 任务描述
  type        String   @default("daily") // daily, weekly
  
  // 每日任务池
  pool        String?  // 任务池名称，用于随机抽取
  
  // 刷新时间
  refreshTime String   @default("00:00") // 刷新时间 HH:MM
  
  // 奖励
  expReward   Int      @default(0)
  silverReward Int     @default(0)
  goldReward  Int      @default(0)
  itemRewards String?  // JSON 数组
  
  // 限制
  maxPerDay   Int      @default(1) // 每日最多完成次数
  
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type])
  @@index([pool])
}

// ============================================
// 成就系统
// ============================================
model Achievement {
  id          String   @id @default(uuid())
  name        String   // 成就名称
  description String   // 成就描述
  category    String   // 分类：combat, gathering, crafting, social, exploration
  type        String   // 类型：kill, collect, craft, reach_level, explore...
  
  // 目标
  targetType  String?  // 目标类型：monster, item, level, zone...
  targetId    String?  // 目标 ID
  targetCount Int      @default(1) // 目标数量
  
  // 奖励
  expReward   Int      @default(0)
  silverReward Int     @default(0)
  goldReward  Int      @default(0)
  title       String?  // 成就称号
  badge       String?  // 成就徽章
  
  // 前置成就
  prerequisites String? // JSON 数组，前置成就 ID
  
  // 隐藏成就
  isHidden    Boolean  @default(false) // 隐藏成就（完成前不显示）
  isRepeatable Boolean @default(false) // 可重复完成
  
  progress    AchievementProgress[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([type])
}

// ============================================
// 成就进度
// ============================================
model AchievementProgress {
  id            String   @id @default(uuid())
  characterId   String
  achievementId String
  current       Int      @default(0) // 当前进度
  completed     Boolean  @default(false) // 是否已完成
  completedAt   DateTime? // 完成时间
  completedCount Int     @default(0) // 完成次数（可重复成就）
  
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  @@unique([characterId, achievementId])
  @@index([characterId])
  @@index([achievementId])
  @@index([completed])
}
