{
  "name": "albion-lands-server",
  "version": "0.1.0",
  "description": "Albion Lands - 2D MMORPG Browser Game Server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "fastify": "^4.24.0",
    "@fastify/websocket": "^8.3.0",
    "ws": "^8.14.0",
    "protobufjs": "^7.2.0",
    "@prisma/client": "^5.7.0",
    "redis": "^4.6.0",
    "amqplib": "^0.10.3",
    "zod": "^2.30.0",
    "winston": "^3.11.0",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.0",
    "@types/amqplib": "^0.10.4",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "prisma": "^5.7.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
